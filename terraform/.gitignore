# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.lock.info

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Saved plan files
*.tfplan
tfplan

# Variable files with sensitive values — use terraform.tfvars.example instead
*.tfvars
!*.tfvars.example

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform/
**/.terraform/
