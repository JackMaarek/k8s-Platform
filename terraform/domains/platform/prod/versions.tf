# versions.tf
# Pinned provider versions — update deliberately, never automatically.
# Run `terraform init -upgrade` after changing versions.

terraform {
  required_version = ">= 1.6.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }

    tls = {
      source  = "hashicorp/tls"
      version = "~> 4.0"
    }
  }
}
