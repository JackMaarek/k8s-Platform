#IDEA
.idea

# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.lock.info

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Saved plan files
*.tfplan
tfplan
plan.json

# Variable files with sensitive values — use terraform.tfvars.example instead
*.tfvars
!*.tfvars.example
!terraform/**/*.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform/
**/.terraform/
.DS_Store
**/.DS_Store
istio-1*

# Ssecrets
*-secrets
*_SECRET*

# Custom
*.zip